# The public endpoint. Either a subdomain (served at root) or host/path-prefix:
#   ENDPOINT=torch-uv.belfner.com
#   ENDPOINT=belfner.com/torch-uv
ENDPOINT=torch-uv.belfner.com

# Email Let's Encrypt uses for expiry notices
ACME_EMAIL=you@example.com

# Traefik image tag
TRAEFIK_IMAGE=traefik:v3.3
